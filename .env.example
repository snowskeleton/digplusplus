# Copy to .env and fill in your values:  cp .env.example .env
#
# Aptabase usage analytics. These values are served to the browser (see
# /config.js), so they are NOT secrets — this file just keeps them out of
# source control and lets you configure them per deployment.
#
# Leave APTABASE_APP_KEY empty to disable analytics entirely (no requests
# are sent, no consent banner needed).

APTABASE_APP_KEY=
APTABASE_HOST=https://metrics.example.com
